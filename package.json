{
  "private": true,
  "description": "Semantic search for coding agent sessions",
  "type": "module",
  "pi": {
    "skills": [
      "./packages/skills"
    ]
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "build:binary": "pnpm --filter @aliou/sesame-cli run build:binary",
    "dev": "./packages/cli/bin/sesame",
    "test": "pnpm -r run test",
    "test:cli": "pnpm --filter @aliou/sesame-cli run test:cli",
    "lint": "biome check",
    "format": "biome check --write",
    "check:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "prepare": "husky",
    "version": "pnpm exec changeset version",
    "prepublishOnly": "pnpm -r run build"
  },
  "author": "Aliou Diallo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/sesame"
  },
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@aliou/biome-plugins": "^0.3.1",
    "@biomejs/biome": "^2.3.14",
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
