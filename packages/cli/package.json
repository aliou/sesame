{
  "name": "@aliou/sesame-cli",
  "version": "0.5.2",
  "private": true,
  "description": "CLI for Sesame semantic search",
  "type": "module",
  "bin": {
    "sesame": "./bin/sesame"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "build:binary": "bun run build.ts",
    "dev": "./bin/sesame",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "test:cli": "bun test ./test/cli.test.ts"
  },
  "author": "Aliou Diallo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/sesame",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@aliou/sesame": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
