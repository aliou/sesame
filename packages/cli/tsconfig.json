{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "types": ["node"],
    "paths": {
      "@aliou/sesame": ["../sesame/index.ts"]
    },
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": false
  },
  "include": ["sesame.ts", "commands/**/*", "test/**/*", "**/*.test.ts", "vitest*.config.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../sesame" }]
}
